# =============================================================================
# TrussC .gitignore
# =============================================================================

# Build artifacts
build/
build-*/
xcode*/
out/
cmake-build-*/
*.a
*.o
*.d
*.lib
*.obj
*.exe
*.dll
*.dylib
*.so
*.pdb

# macOS
.DS_Store
*.dSYM/

# =============================================================================
# IDE / Editor
# =============================================================================

# Visual Studio Code
.vscode/

# Visual Studio
.vs/
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln
*.suo
*.user
*.userosscache
*.sln.docstates

# Xcode
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.xcuserstate

# JetBrains (CLion)
.idea/
*.iml

# =============================================================================
# CMake
# =============================================================================
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json
CTestTestfile.cmake
_deps/

# clangd cache
.cache/

# =============================================================================
# Examples
# =============================================================================

# Exclude build artifacts in examples (including subfolders)
examples/**/build/
examples/**/bin/*
!examples/**/bin/data/
examples/**/out/
examples/**/*.xcodeproj/
examples/**/*.sln
examples/**/*.vcxproj

# =============================================================================
# Addons
# =============================================================================

# Exclude build artifacts in addons
addons/**/build/
addons/**/bin/*
!addons/**/bin/data/
addons/**/*.xcodeproj/
addons/**/*.sln
addons/**/*.vcxproj

# =============================================================================
# Exclude Non official addons
# =============================================================================

addons/*
!addons/tcxBox2d
!addons/tcxCurl
!addons/tcxImGui
!addons/tcxHap
!addons/tcxLua
!addons/tcxLut
!addons/tcxOsc
!addons/tcxQuadWarp
!addons/tcxTls
!addons/tcxWebSocket
!addons/tcxGltf
!addons/tcxObj

# =============================================================================
# trusscli / Project Generator (built binary + build artifacts in tools/)
# =============================================================================

# Exclude trusscli binaries and build output (only source is tracked).
# trusscli is the single binary that backs both the CLI and the GUI
# ("TrussC Project Generator").
tools/trusscli.app
tools/trusscli.exe
tools/trusscli
tools/bin/
tools/build/

# =============================================================================
# Tools (auto-downloaded)
# =============================================================================

# Tools like sokol-shdc are auto-downloaded on first build
core/tools/
docs/scripts/node_modules/

# =============================================================================
# Project Generator Auto-generated Files
# =============================================================================
examples/**/CMakePresets.json
examples/**/build-web.command
examples/**/build-web.bat
examples/**/build-web.sh
addons/**/CMakePresets.json
addons/**/build-web.command
addons/**/build-web.bat
addons/**/build-web.sh
examples/CMakeLists.txt
addons/CMakeLists.txt

# =============================================================================
# Auto-generated Shader Headers (sokol-shdc output)
# =============================================================================
core/include/tc/gpu/shaders/*.glsl.h

# =============================================================================
# AI assistant local state
# =============================================================================
# Project-local state/settings from AI coding tools. Root-level instruction
# files like CLAUDE.md / GEMINI.md / AGENTS.md are intentionally *not* ignored
# since those are meant to be shared.
.claude/
.gemini/
.codex/
.cursor/
.windsurf/
.continue/
.amazonq/
.cline/
.clinerules/
.aider*
